<%= render 'partials/header' %>
<div class="parent">
  <turbo-frame id="search" class="child">
    <div class="child">
      <form action="/search-ticker" method="post">
        <input data-turbo-frame type="text" name="ticker" placeholder="Ticker e.g. MSFT" required>
        <button class="btn btn-success" type="submit">Search</button>
      </form>
    </div>

    <div class="container">
      <% if defined? results %>
          <div class="row bg-light">
            <div class="col">Symbol</div>
            <div class="col">Short Name</div>
          </div>
          <% results.each do |quote| %>
            <% next unless quote['score'] > 100000 %>
            <div class="row">
              <div class="col">
                <a href="<%= "/ticker/#{quote['symbol']}" %>" data-turbo="false" class="link-info">
                <%= quote['symbol'] %>
                </a>
              </div>
              <div class="col" style="min-width: fit-content"><%= quote['shortname'] %></div>
            </div>
          <% end %>
      <% end %>
    </div>
  </turbo-frame>
</div>